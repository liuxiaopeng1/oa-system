{"remainingRequest":"E:\\vs_workspace\\tlias-web\\node_modules\\babel-loader\\lib\\index.js!E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!E:\\vs_workspace\\tlias-web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\vs_workspace\\tlias-web\\src\\views\\dept\\index.vue?vue&type=script&lang=js&","dependencies":[{"path":"E:\\vs_workspace\\tlias-web\\src\\views\\dept\\index.vue","mtime":1685878437770},{"path":"E:\\vs_workspace\\tlias-web\\babel.config.js","mtime":1637306514000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1659247428000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\babel-loader\\lib\\index.js","mtime":1659247422000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1659247428000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\vue-loader\\lib\\index.js","mtime":1659247426000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAwEA;AAEA;EACAA,IADA,kBACA;IACA;MACAC,uBADA;MAEAC,wBAFA;MAEA;MACAC;QACAC;MADA,CAHA;MAMAC,aANA;MAOAC;QACAF,OACA;UAAAG;UAAAC;UAAAC;QAAA,CADA,EAEA;UAAAC;UAAAC;UAAAH;UAAAC;QAAA,CAFA;MADA;IAPA;EAcA,CAhBA;EAkBAG;IAEA;IACAC,UAHA,sBAGAC,EAHA,EAGA;MAAA;;MACA;QACAC,uBADA;QAEAC,sBAFA;QAGAC;MAHA,GAIAC,IAJA,CAIA;QACAL;UACA;YACA;cACAL,mBADA;cAEAS;YAFA;UAIA,CALA,MAKA;YACA;UACA,CARA,CASA;;;UACA;QACA,CAXA;MAYA,CAjBA,EAiBAE,KAjBA,CAiBA;QACA;UACAF,YADA;UAEAT;QAFA;MAIA,CAtBA;IAuBA,CA3BA;IA6BA;IACAY,UA9BA,sBA8BAN,EA9BA,EA8BA;MAAA;;MACA;;MACAM;QACA;MACA,CAFA;IAGA,CAnCA;IAqCA;IACAC,IAtCA,gBAsCAC,QAtCA,EAsCA;MAAA;;MACA;;MACA;QACAC,6BADA,CACA;MACA,CAFA,MAEA;QACAA,0BADA,CACA;MACA;;MACA;QACA;UACAC;UACAD;YACA;cACA;cACA,oCAFA,CAGA;;;cACA,cAJA,CAKA;;;cACA,iCANA,CAOA;;cACA;YACA,CATA,MASA;cACA;YACA;UACA,CAbA;QAcA,CAhBA,MAgBA;UACA;QACA;MACA,CApBA;IAqBA,CAlEA;IAoEA;IACAE,IArEA,kBAqEA;MAAA;;MACAC;QACAC;;QACA;UACA;QACA;MACA,CALA;IAMA;EA5EA,CAlBA;EAgGAC,OAhGA,qBAgGA;IACA;IACA;EACA;AAnGA","names":["data","formLabelWidth","dialogFormVisible","dept","name","tableData","rules","required","message","trigger","min","max","methods","deleteById","id","confirmButtonText","cancelButtonText","type","then","catch","selectById","save","formName","operator","alert","init","findAll","console","mounted"],"sourceRoot":"src/views/dept","sources":["index.vue"],"sourcesContent":["<template>\n  <div style=\"margin-top: 20px; margin: 50px; margin-right: 100px\">\n    <!-- 按钮 -->\n\n    <el-row>\n      <el-button\n        style=\"float: right\"\n        type=\"primary\"\n        @click=\"dialogFormVisible = true; dept={}\"\n        >+ 新增部门</el-button\n      >\n    </el-row>\n    <br>\n    <!-- 数据表格 -->\n    <template>\n      <el-table\n        highlight-current-row\n        ref=\"multipleTable\"\n        :data=\"tableData\"\n        tooltip-effect=\"dark\"\n        style=\"width: 100%\"\n        border\n      >\n        <el-table-column type=\"index\" width=\"100\" label=\"序号\" header-align=\"center\" align=\"center\"> </el-table-column>\n        <el-table-column prop=\"name\" label=\"部门名称\" header-align=\"center\" align=\"center\"></el-table-column>\n        <el-table-column label=\"最后操作时间\" header-align=\"center\" align=\"center\">\n          <template slot-scope=\"scope\">\n              {{scope.row.updateTime ? scope.row.updateTime.replace('T',' '):''}}\n          </template>\n        </el-table-column>\n\n        <el-table-column label=\"操作\" width=\"420\" header-align=\"center\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-button\n              size=\"mini\"\n              type=\"primary\"\n              plain\n              @click=\"selectById(scope.row.id)\"\n              >编辑</el-button\n            >\n\n            <el-button\n              size=\"mini\"\n              type=\"danger\"\n              plain\n              @click=\"deleteById(scope.row.id)\"\n              >删除</el-button\n            >\n          </template>\n        </el-table-column>\n      </el-table>\n    </template>\n\n    <!-- 新建对话框 -->\n\n    <el-dialog title=\"保存部门\" :visible.sync=\"dialogFormVisible\" >\n      <el-form :model=\"dept\" :rules=\"rules\" ref=\"dept\">\n        <el-form-item label=\"部门名称\" :label-width=\"formLabelWidth\" prop=\"name\">\n          <el-input v-model=\"dept.name\"  placeholder=\"请输入部门名称\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n      </el-form>\n\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save('dept')\">确 定</el-button>\n      </div>\n    </el-dialog>\n\n  </div>\n</template>\n\n<script>\nimport { findAll, add, update, deleteById, selectById } from \"@/api/dept.js\";\n\nexport default {\n  data() {\n    return {\n      formLabelWidth: \"120px\",\n      dialogFormVisible: false, //控制对话框是否可见\n      dept: {\n        name: \"\",\n      },\n      tableData: [],\n      rules: {\n          name: [\n            { required: true, message: '请输入部门名称', trigger: 'blur' },\n            { min: 2, max: 10, message: '长度在 2 到 10 个字符', trigger: 'blur' }\n          ]\n      }    \n    };\n  },\n\n  methods: {\n\n    //删除部门\n    deleteById(id) {\n      this.$confirm(\"确认删除?\", \"提示\", {\n        confirmButtonText: \"确定\",\n        cancelButtonText: \"取消\",\n        type: \"warning\",\n      }).then(() => {\n          deleteById(id).then((result) => {\n          \tif(result.data.code == 1){\n\t          \tthis.$message({\n\t              message: \"恭喜你，删除成功\",\n\t              type: \"success\",\n\t            });\n\t        }else{\n\t        \tthis.$message.error(result.data.msg);\n\t        }\n            //重新查询数据\n            this.init();\n          });\n        }).catch(() => {\n          this.$message({\n            type: \"info\",\n            message: \"已取消删除\",\n          });\n        });\n    },\n\n    //根据ID查询部门 -- 回显\n    selectById(id) {\n      this.dialogFormVisible = true;\n      selectById(id).then((result) => {\n        this.dept = result.data.data;\n      });\n    },\n\n    //保存方法\n    save(formName) {\n      let operator ;\n      if (this.dept.id) {\n        operator = update(this.dept); // 修改\n      }else{\n        operator = add(this.dept); //添加 \n      }\n       this.$refs[formName].validate((valid) => {\n          if(valid){\n            alert(valid)\n            operator.then((result) => {\n              if (result.data.code == 1) {\n                //修改成功\n                this.$message.success(\"恭喜你，保存成功\");\n                //重新查询数据\n                this.init();\n                // 关闭新建窗口\n                this.dialogFormVisible = false;\n                // 清空模型数据\n                this.dept = {};\n              } else {\n                this.$message.error(result.data.msg);\n              }\n            });\n          }else {\n            return false;\n          }\n       })\n    },\n\n    //初始化 - 查询全部\n    init() {\n      findAll().then((result) => {\n        console.log(result);\n        if (result.data.code == 1) {\n          this.tableData = result.data.data;\n        }\n      });\n    },\n  },\n  mounted() {\n    //当页面加载完成后自动执行。\n    this.init();\n  },\n};\n</script>\n<style>\n\n</style>\n"]}]}