error)\r\n      let { message } = error;\r\n      if (message == \"Network Error\") {\r\n        message = \"后端接口连接异常\";\r\n      }\r\n      else if (message.includes(\"timeout\")) {\r\n        message = \"系统接口请求超时\";\r\n      }\r\n      else if (message.includes(\"Request failed with status code\")) {\r\n        message = \"系统接口\" + message.substr(message.length - 3) + \"异常\";\r\n      }\r\n      return Promise.reject(error)\r\n\r\n})\r\n\r\nexport default service\r\n"],"mappings":";;;;;AACA,OAAOA,KAAP,MAAkB,OAAlB;AACA,OAAOC,MAAP,MAAmB,UAAnB;AACA,SAASC,WAAT,EAAsBC,QAAtB,QAAsC,cAAtC;AAEA,IAAMC,OAAO,GAAGJ,KAAK,CAACK,MAAN,CAAa;EAC3BC,OAAO,EAAEC,OAAO,CAACC,GAAR,CAAYC,gBADM;EACY;EACvCC,eAAe,EAAE,IAFU;EAG3BC,OAAO,EAAE;AAHkB,CAAb,CAAhB,C,CAOA;;AACAP,OAAO,CAACQ,YAAR,CAAqBC,OAArB,CAA6BC,GAA7B,CACE,UAAAC,MAAM,EAAI;EACR,IAAIC,KAAK,GAAGb,QAAQ,EAApB;;EACA,IAAGa,KAAH,EAAS;IACPD,MAAM,CAACE,OAAP,CAAe,OAAf,IAA0BD,KAA1B;EACD;;EACD,OAAOD,MAAP;AACD,CAPH,EAQE,UAAAG,KAAK,EAAI;EACPC,OAAO,CAACC,GAAR,CAAYF,KAAZ;EACA,OAAOG,OAAO,CAACC,MAAR,CAAeJ,KAAf,CAAP;AACD,CAXH,E,CAeA;;AACAd,OAAO,CAACQ,YAAR,CAAqBW,QAArB,CAA8BT,GAA9B,CAAkC,UAAAU,GAAG,EAAE;EACnC,IAAIA,GAAG,CAACC,IAAJ,CAASC,IAAT,KAAkB,CAAlB,IAAuBF,GAAG,CAACC,IAAJ,CAASE,GAAT,KAAiB,WAA5C,EAAyD;IAAC;IACtDR,OAAO,CAACC,GAAR,CAAY,kBAAZ;IACAlB,WAAW;IACXD,MAAM,CAAC2B,OAAP,CAAe,QAAf;IACA,OAAOP,OAAO,CAACC,MAAR,CAAe,IAAIO,KAAJ,CAAU,WAAV,CAAf,CAAP;EACD,CALH,MAKS;IACL,OAAOL,GAAP;EACD;AACF,CATL,EAWI,UAAAN,KAAK,EAAI;EACPC,OAAO,CAACC,GAAR,CAAY,QAAQF,KAApB;EACA,IAAMY,OAAN,GAAkBZ,KAAlB,CAAMY,OAAN;;EACA,IAAIA,OAAO,IAAI,eAAf,EAAgC;IAC9BA,OAAO,GAAG,UAAV;EACD,CAFD,MAGK,IAAIA,OAAO,CAACC,QAAR,CAAiB,SAAjB,CAAJ,EAAiC;IACpCD,OAAO,GAAG,UAAV;EACD,CAFI,MAGA,IAAIA,OAAO,CAACC,QAAR,CAAiB,iCAAjB,CAAJ,EAAyD;IAC5DD,OAAO,GAAG,SAASA,OAAO,CAACE,MAAR,CAAeF,OAAO,CAACG,MAAR,GAAiB,CAAhC,CAAT,GAA8C,IAAxD;EACD;;EACD,OAAOZ,OAAO,CAACC,MAAR,CAAeJ,KAAf,CAAP;AAEL,CAzBD;AA2BA,eAAed,OAAf"}]}