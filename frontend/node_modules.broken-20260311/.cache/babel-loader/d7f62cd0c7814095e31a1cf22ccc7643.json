{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js!/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/login/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/login/index.vue","mtime":1772614806209},{"path":"/Users/liuxiaopeng/tlias-web/babel.config.js","mtime":1772100774988},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js","mtime":1772101406962},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkDA;AACA;AACA;EACAA,aADA;EAEAC,IAFA,kBAEA;IACA;MACAC;QACAC,YADA;QAEAC;MAFA,CADA;MAKAC;QACAF;UAAAG;UAAAC;UAAAC;QAAA,EADA;QAEAJ;UAAAE;UAAAC;UAAAC;QAAA;MAFA,CALA;MASAC,cATA;MAUAC,wBAVA;MAWAC;IAXA;EAaA,CAhBA;EAiBAC;IACAC;MACAC,OADA,mBACAC,KADA,EACA;QACA;MACA,CAHA;MAIAC;IAJA;EADA,CAjBA;EA0BAC;IACAC,OADA,qBACA;MAAA;;MACA;QACA;MACA,CAFA,MAEA;QACA;MACA;;MACA;QACA;MACA,CAFA;IAGA,CAVA;IAYAC,WAZA,yBAYA;MAAA;;MACA;QACA;UACA;UAEAC;YACA;cACAC;;cACA;YACA,CAHA,MAGA;cACA;YACA;UACA,CAPA,EAOAC,OAPA,CAOA;YACA;UACA,CATA;QAUA,CAbA,MAaA;UACA;QACA;MACA,CAjBA;IAkBA;EA/BA;AA1BA","names":["name","data","loginForm","username","password","loginRules","required","message","trigger","loading","passwordType","redirect","watch","$route","handler","route","immediate","methods","showPwd","handleLogin","login","setToken","finally"],"sourceRoot":"src/views/login","sources":["index.vue"],"sourcesContent":["<template>\n  <div class=\"login-container\">\n    <el-form ref=\"loginForm\" :model=\"loginForm\" :rules=\"loginRules\" class=\"login-form\" auto-complete=\"on\" label-position=\"left\">\n\n      <div class=\"title-container\">\n        <h3 class=\"title\">黑马程序员Tlias智能学习辅助系统</h3>\n      </div>\n\n      <el-form-item prop=\"username\">\n        <span class=\"svg-container\">\n          <svg-icon icon-class=\"user\" />\n        </span>\n        <el-input\n          ref=\"username\"\n          v-model=\"loginForm.username\"\n          placeholder=\"Username\"\n          name=\"username\"\n          type=\"text\"\n          tabindex=\"1\"\n          auto-complete=\"on\"\n        />\n      </el-form-item>\n\n      <el-form-item prop=\"password\">\n        <span class=\"svg-container\">\n          <svg-icon icon-class=\"password\" />\n        </span>\n        <el-input\n          :key=\"passwordType\"\n          ref=\"password\"\n          v-model=\"loginForm.password\"\n          :type=\"passwordType\"\n          placeholder=\"Password\"\n          name=\"password\"\n          tabindex=\"2\"\n          auto-complete=\"on\"\n          @keyup.enter.native=\"handleLogin\"\n        />\n        <span class=\"show-pwd\" @click=\"showPwd\">\n          <svg-icon :icon-class=\"passwordType === 'password' ? 'eye' : 'eye-open'\" />\n        </span>\n      </el-form-item>\n\n      <el-button :loading=\"loading\" type=\"primary\" style=\"width:100%;margin-bottom:30px;\" @click.native.prevent=\"handleLogin\">Login</el-button>\n\n    </el-form>\n  </div>\n</template>\n\n<script>\nimport { login } from '@/api/user'\nimport { setToken } from '@/utils/auth'\nexport default {\n  name: 'Login',\n  data() {\n    return {\n      loginForm: {\n        username: '',\n        password: ''\n      },\n      loginRules: {\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }]\n      },\n      loading: false,\n      passwordType: 'password',\n      redirect: undefined\n    }\n  },\n  watch: {\n    $route: {\n      handler(route) {\n        this.redirect = route.query && route.query.redirect\n      },\n      immediate: true\n    }\n  },\n\n  methods: {\n    showPwd() {\n      if (this.passwordType === 'password') {\n        this.passwordType = ''\n      } else {\n        this.passwordType = 'password'\n      }\n      this.$nextTick(() => {\n        this.$refs.password.focus()\n      })\n    },\n    \n    handleLogin() {\n      this.$refs.loginForm.validate(valid => {\n        if (valid) {\n          this.loading = true\n\n          login(this.loginForm).then((result) => {\n            if (result.data.code === 1) {\n              setToken(result.data.data)\n              this.$router.push(this.redirect || '/dashboard')\n            } else {\n              this.$message.error(result.data.msg || '登录失败')\n            }\n          }).finally(() => {\n            this.loading = false\n          })\n        } else {\n          return false\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\">\n/* 修复input 背景不协调 和光标变色 */\n/* Detail see https://github.com/PanJiaChen/vue-element-admin/pull/927 */\n\n$bg:#283443;\n$light_gray:#fff;\n$cursor: #fff;\n\n@supports (-webkit-mask: none) and (not (cater-color: $cursor)) {\n  .login-container .el-input input {\n    color: $cursor;\n  }\n}\n\n/* reset element-ui css */\n.login-container {\n  .el-input {\n    display: inline-block;\n    height: 47px;\n    width: 85%;\n\n    input {\n      background: transparent;\n      border: 0px;\n      -webkit-appearance: none;\n      border-radius: 0px;\n      padding: 12px 5px 12px 15px;\n      color: $light_gray;\n      height: 47px;\n      caret-color: $cursor;\n\n      &:-webkit-autofill {\n        box-shadow: 0 0 0px 1000px $bg inset !important;\n        -webkit-text-fill-color: $cursor !important;\n      }\n    }\n  }\n\n  .el-form-item {\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    background: rgba(0, 0, 0, 0.1);\n    border-radius: 5px;\n    color: #454545;\n  }\n}\n</style>\n\n<style lang=\"scss\" scoped>\n$bg:#2d3a4b;\n$dark_gray:#889aa4;\n$light_gray:#eee;\n\n.login-container {\n  min-height: 100%;\n  width: 100%;\n  background-color: $bg;\n  overflow: hidden;\n\n  .login-form {\n    position: relative;\n    width: 520px;\n    max-width: 100%;\n    padding: 160px 35px 0;\n    margin: 0 auto;\n    overflow: hidden;\n  }\n\n  .tips {\n    font-size: 14px;\n    color: #fff;\n    margin-bottom: 10px;\n\n    span {\n      &:first-of-type {\n        margin-right: 16px;\n      }\n    }\n  }\n\n  .svg-container {\n    padding: 6px 5px 6px 15px;\n    color: $dark_gray;\n    vertical-align: middle;\n    width: 30px;\n    display: inline-block;\n  }\n\n  .title-container {\n    position: relative;\n\n    .title {\n      font-size: 26px;\n      color: $light_gray;\n      margin: 0px auto 40px auto;\n      text-align: center;\n      font-weight: bold;\n      font-family: '楷体';\n    }\n  }\n\n  .show-pwd {\n    position: absolute;\n    right: 10px;\n    top: 7px;\n    font-size: 16px;\n    color: $dark_gray;\n    cursor: pointer;\n    user-select: none;\n  }\n}\n</style>\n"]}]}