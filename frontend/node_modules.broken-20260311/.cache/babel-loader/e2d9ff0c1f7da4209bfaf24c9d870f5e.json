{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js!/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/student-report/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/student-report/index.vue","mtime":1772187011994},{"path":"/Users/liuxiaopeng/tlias-web/babel.config.js","mtime":1772100774988},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js","mtime":1772101406962},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":";;;;;;;;;;;AAYA;AACA;AAEA;EACAA,IADA,kBACA;IACA;MACAC,kBADA;MAEAC,oBAFA;MAGAC;IAHA;EAKA,CAPA;EASAC,OATA,qBASA;IACA,sBADA,CACA;;IACAC;EACA,CAZA;EAaAC,aAbA,2BAaA;IACAD;;IACA;MACA;MACA;IACA;EACA,CAnBA;EAqBAE;IACA;IACAC,cAFA,4BAEA;MAAA;;MACAA;QACA;UACA;UACA;;UAEA;QACA;MACA,CAPA;IAQA,CAXA;IAaAC,UAbA,wBAaA;MACA;QACA;MACA;;MAEA;QACAC;UACAC,gBADA;UAEAX;QAFA,CADA;QAKAY;UACAD;QADA,CALA;QAQAE,SACA;UACAb,2BADA;UAEAW;QAFA,CADA;MARA;MAgBA;IACA,CAnCA;IAoCAG,YApCA,0BAoCA;MACA;QACA;MACA;IACA;EAxCA;AArBA","names":["data","clazzCountList","studentCountList","studentChart","mounted","window","beforeDestroy","methods","getStudentData","initChart1","xAxis","type","yAxis","series","handleResize"],"sourceRoot":"src/views/student-report","sources":["index.vue"],"sourcesContent":["<template>\n  <div class=\"chart-container\">\n\n    <div  style=\"width: 100%; \">\n      <h1>班级人数统计</h1> <br>\n      <div ref=\"studentChartRef\" style=\"width: 100%; height: 500px\"></div>\n    </div>\n\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport { getStudentData } from \"@/api/report.js\";\n\nexport default {\n  data() {\n    return {\n      clazzCountList: [],\n      studentCountList: [],\n      studentChart: null\n    }\n  },\n\n  mounted() { \n    this.getStudentData(); //获取班级学生统计数据\n    window.addEventListener('resize', this.handleResize)\n  },\n  beforeDestroy() {\n    window.removeEventListener('resize', this.handleResize)\n    if (this.studentChart) {\n      this.studentChart.dispose()\n      this.studentChart = null\n    }\n  },\n\n  methods: {\n    //获取班级学生统计数据\n    getStudentData(){\n      getStudentData().then((result) => {\n          if(result.data.code == 1){\n             this.clazzCountList = result.data.data.categoryList;\n             this.studentCountList = result.data.data.dataList;\n             \n             this.initChart1();\n          }\n      });\n    },\n    \n    initChart1() {\n      if (!this.studentChart) {\n        this.studentChart = echarts.init(this.$refs.studentChartRef)\n      }\n       \n      let option = {\n        xAxis: {\n          type: 'category',\n          data: this.clazzCountList\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [\n          {\n            data: this.studentCountList,\n            type: 'bar'\n          }\n        ]\n      };\n      \n      this.studentChart.setOption(option);\n    },\n    handleResize() {\n      if (this.studentChart) {\n        this.studentChart.resize()\n      }\n    }\n  }\n};\n</script>\n\n<style>\n  h1 {\n    text-align: center;\n  }\n\n  .chart-container {\n    display: flex;\n  }\n  .chart-container > div {\n    flex: 1;\n  }\n</style>\n"]}]}