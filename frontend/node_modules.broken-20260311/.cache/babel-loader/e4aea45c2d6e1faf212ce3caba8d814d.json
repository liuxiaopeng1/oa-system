{"remainingRequest":"E:\\vs_workspace\\tlias-web\\node_modules\\babel-loader\\lib\\index.js!E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!E:\\vs_workspace\\tlias-web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\vs_workspace\\tlias-web\\src\\views\\student\\index.vue?vue&type=script&lang=js&","dependencies":[{"path":"E:\\vs_workspace\\tlias-web\\src\\views\\student\\index.vue","mtime":1685886501767},{"path":"E:\\vs_workspace\\tlias-web\\babel.config.js","mtime":1637306514000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1659247428000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\babel-loader\\lib\\index.js","mtime":1659247422000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1659247428000},{"path":"E:\\vs_workspace\\tlias-web\\node_modules\\vue-loader\\lib\\index.js","mtime":1659247426000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA0JA;AACA;AAEA;EACAA,IADA,kBACA;IACA;MACAC,gBADA;MAEA;MACAC,WAHA;MAIA;MACAC,eALA;MAMA;MACAC,cAPA;MAQA;MACAC,oBATA;MAUA;MACAC,6BAXA;MAYA;MACAC;QACAC,QADA;QAEAC,MAFA;QAGAC,UAHA;QAIAC;MAJA,CAbA;MAmBAC;QACAJ,QADA;QAEAC,MAFA;QAGAI,UAHA;QAIAC,SAJA;QAKAJ,UALA;QAMAK;MANA,CAnBA;MA2BAC;QACAC,MADA;QAEAC;MAFA,CA3BA;MA+BAC,aA/BA;MAgCAC;QAAAH;QAAAT;MAAA;QAAAS;QAAAT;MAAA,EAhCA;MAiCAa,aACA;QAAAJ;QAAAT;MAAA,CADA,EAEA;QAAAS;QAAAT;MAAA,CAFA,EAGA;QAAAS;QAAAT;MAAA,CAHA,EAIA;QAAAS;QAAAT;MAAA,CAJA,EAKA;QAAAS;QAAAT;MAAA,CALA,EAMA;QAAAS;QAAAT;MAAA,CANA,CAjCA;MA0CAc,aA1CA;MA2CAC,WA3CA;MA6CA;MACAC,eA9CA;MA+CA;MACAC,qBAhDA;MAiDA;MACAC;IAlDA;EAoDA,CAtDA;EAwDAC,OAxDA,qBAwDA;IAAA;;IACA,YADA,CACA;;IACAC;MACA;IACA,CAFA;EAGA,CA7DA;EA+DAC;IACA;IACAC,IAFA,kBAEA;MAAA;;MACAA,MACA,mBADA,EAEA,iBAFA,EAGA,qBAHA,EAIA,sBAJA,EAKA,gBALA,EAMA,aANA,EAOAC,IAPA,CAOA;QACA;QACA;MACA,CAVA;IAWA,CAdA;IAgBA;IACAC,qBAjBA,iCAiBAC,GAjBA,EAiBA;MACA;IACA,CAnBA;IAqBA;IACAC,QAtBA,sBAsBA;MACA;MACA;IACA,CAzBA;IA2BAC,KA3BA,mBA2BA;MACA;QAAA3B;QAAAC;QAAAC;QAAAC;MAAA;MACA;IACA,CA9BA;IAgCA;IACAyB,IAjCA,kBAiCA;MAAA;;MACA;;MAEA;QAAA;QACAC;MACA,CAFA,MAEA;QAAA;QACAA;MACA;;MAEAA;QACA;UACA;;UACA;;UACA;YAAAC;YAAAC;UAAA;;UACA;YAAAC;UAAA;QACA,CALA,MAKA;UACA;QACA;MACA,CATA;IAUA,CApDA;IAsDAC,MAtDA,kBAsDAxB,EAtDA,EAsDA;MAAA;;MACA;MACA,0BAFA,CAGA;;MAEAyB;QACA;UACA;QACA;MACA,CAJA;IAKA,CAhEA;IAmEA;IACAC,gBApEA,4BAoEAV,GApEA,EAoEA;MACA;MACA;MACA;IACA,CAxEA;IA0EAW,mBA1EA,+BA0EAX,GA1EA,EA0EA;MACA;MACA;MACA;IACA,CA9EA;IAiFA;IACAY,UAlFA,sBAkFA5B,EAlFA,EAkFA;MAAA;;MACA;QACA6B,uBADA;QAEAC,sBAFA;QAGAR;MAHA,GAIAR,IAJA,CAIA;QACA;QACAc;UACA;YACA;YACA;;YACA;UACA,CAJA,MAIA;YACA;UACA;QACA,CARA;MASA,CAfA,EAeAG,KAfA,CAeA;QACA;QACA;MACA,CAlBA;IAmBA,CAtGA;IAyGA;IACAC,WA1GA,yBA0GA;MAAA;;MACA;QACA;QACA;MACA,CAJA,CAMA;;;MACA;QACAH,uBADA;QAEAC,sBAFA;QAGAR;MAHA,GAIAR,IAJA,CAIA;QACA;QACA;QACA;UACA;QACA,CALA,CAOA;;;QACAc;UACA;YACA;YACA;;YACA;UACA,CAJA,MAIA;YACA;UACA;QACA,CARA;MASA,CArBA,EAqBAG,KArBA,CAqBA;QACA;QACA;MACA,CAxBA;IAyBA,CA1IA;IA4IA;IACAE,aA7IA,yBA6IAjC,EA7IA,EA6IA;MACA;MACA;MACA;IACA,CAjJA;IAmJA;IACAkC,eApJA,6BAoJA;MAAA;;MACAA;QACA;UACA;;UACA;;UACA;QACA,CAJA,MAIA;UACA;QACA;MACA,CARA;IASA,CA9JA;IAgKA;IACAC,mBAjKA,+BAiKAC,GAjKA,EAiKAC,IAjKA,EAiKA;MACA;IACA,CAnKA;IAqKAC,kBArKA,8BAqKAD,IArKA,EAqKA;MACA;MACA;;MACA;QACA;MACA;;MACA;QACA;MACA;;MACA;IACA;EA/KA;AA/DA","names":["data","background","pageSize","totalCount","currentPage","dialogVisible","dialogViolationVisible","searchStu","name","no","degree","clazzId","student","gender","phone","classId","violationForm","id","score","clazzList","genderList","degreeList","beginTime","endTime","selectedIds","multipleSelection","tableData","mounted","findAll","methods","page","then","handleSelectionChange","val","onSubmit","clear","save","operator","message","type","image","update","selectById","handleSizeChange","handleCurrentChange","deleteById","confirmButtonText","cancelButtonText","catch","deleteByIds","violationById","violationHandle","handleAvatarSuccess","res","file","beforeAvatarUpload"],"sourceRoot":"src/views/student","sources":["index.vue"],"sourcesContent":["<template>\n  <div class=\"app-container\">\n\n    <!--搜索表单-->\n    <el-form :inline=\"true\" :model=\"searchStu\" class=\"demo-form-inline\">\n      <el-form-item label=\"姓名\">\n        <el-input v-model=\"searchStu.name\" placeholder=\"请输入学员姓名\"></el-input>\n      </el-form-item>\n\n      <el-form-item label=\"学号\">\n        <el-input v-model=\"searchStu.no\" placeholder=\"请输入学员学号\"></el-input>\n      </el-form-item>\n\n      <el-form-item label=\"学历\">\n        <el-select v-model=\"searchStu.degree\" placeholder=\"请选择\">\n          <el-option :label=\"degree.name\" :value=\"degree.id\" v-for=\"(degree,index) in degreeList\" :key=\"index\"></el-option>\n        </el-select>\n      </el-form-item>\n\n      <el-form-item label=\"所属班级\">\n        <el-select v-model=\"searchStu.clazzId\" placeholder=\"请选择\">\n          <el-option :label=\"clazz.name\" :value=\"clazz.id\" v-for=\"(clazz,index) in clazzList\" :key=\"index\"></el-option>\n        </el-select>\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" @click=\"onSubmit\">查询</el-button>\n         <el-button type=\"info\" @click=\"clear\">清空</el-button>\n      </el-form-item>\n    </el-form>\n\n\n    <!--按钮-->\n    <el-row>\n      <el-button type=\"primary\" size=\"medium\" @click=\"dialogVisible = true; student = {};\" >+ 新增学员</el-button>\n      <el-button type=\"danger\" size=\"medium\" @click=\"deleteByIds\">- 批量删除</el-button>\n    </el-row> \n\n\n    <!--添加数据对话框表单-->\n    <el-dialog ref=\"form\" title=\"编辑学员\" :visible.sync=\"dialogVisible\" width=\"30%\">\n      <el-form ref=\"form\" :model=\"student\" label-width=\"80px\" size=\"mini\">\n        \n        <el-form-item label=\"姓名\">\n          <el-input v-model=\"student.name\"></el-input>\n        </el-form-item>\n\n        <el-form-item label=\"学号\">\n          <el-input v-model=\"student.no\"></el-input>\n        </el-form-item>\n\n        <el-form-item label=\"性别\" >\n          <el-select v-model=\"student.gender\" placeholder=\"请选择\" style=\"width:100%\" >\n             <el-option v-for=\"item in genderList\" :key=\"item.value\" :label=\"item.name\" :value=\"item.id\"/>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"手机号\">\n          <el-input v-model=\"student.phone\"></el-input>\n        </el-form-item>\n\n        <el-form-item label=\"最高学历\" >\n          <el-select v-model=\"student.degree\" placeholder=\"请选择\" style=\"width:100%\" >\n             <el-option v-for=\"item in degreeList\" :key=\"item.value\" :label=\"item.name\" :value=\"item.id\"/>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"所属班级\" >\n          <el-select v-model=\"student.clazzId\" placeholder=\"请选择\" style=\"width:100%\" >\n             <el-option v-for=\"clazz in clazzList\" :key=\"clazz.id\" :label=\"clazz.name\" :value=\"clazz.id\"/>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"save\">提交</el-button>\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\n        </el-form-item>\n      </el-form>\n    </el-dialog>\n\n    <br>\n\n    <!--表格-->\n    <template>\n      <el-table :data=\"tableData\" style=\"width: 100%\" border @selection-change=\"handleSelectionChange\">\n        <el-table-column type=\"selection\" width=\"40\"  align=\"center\"></el-table-column>\n        <el-table-column  prop=\"name\"  label=\"姓名\"  width=\"90\" align=\"center\"></el-table-column>\n        <el-table-column  prop=\"no\"  label=\"学号\" width=\"110\" align=\"center\"></el-table-column>\n        <el-table-column  prop=\"clazzName\"  label=\"班级\"  align=\"center\"></el-table-column>\n        <el-table-column align=\"center\" label=\"性别\" width=\"60\">\n          <template slot-scope=\"scope\"><span style=\"margin-right: 10px\"> {{scope.row.gender == \"1\" ? \"男\" : \"女\"}}</span></template>\n        </el-table-column>\n        <el-table-column prop=\"phone\" label=\"手机号\" align=\"center\" width=\"110\"></el-table-column>\n        <el-table-column align=\"center\" label=\"最高学历\" width=\"90\">\n          <template slot-scope=\"scope\">\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 1\">初中</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 2\">高中</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 3\">大专</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 4\">本科</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 5\">硕士</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.degree == 6\">博士</span>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"violationCount\" label=\"违纪次数\" align=\"center\" width=\"90\"></el-table-column>\n        <el-table-column prop=\"violationScore\" label=\"违纪扣分\" align=\"center\" width=\"90\"></el-table-column>\n        <el-table-column align=\"center\" label=\"最后操作时间\" width=\"170\">\n          <template slot-scope=\"scope\">{{scope.row.updateTime ? scope.row.updateTime.replace('T',' '):''}}</template>\n        </el-table-column>\n        <el-table-column align=\"center\" label=\"操作\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"primary\" size=\"small\" @click=\"update(scope.row.id)\">编辑</el-button>\n            <el-button type=\"warning\" size=\"small\" @click=\"violationById(scope.row.id)\">违纪</el-button>\n            <el-button type=\"danger\" size=\"small\" @click=\"deleteById(scope.row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </template>\n\n    <br>\n\n    <!--分页工具条-->\n    <el-pagination\n      @size-change=\"handleSizeChange\"\n      @current-change=\"handleCurrentChange\"\n      :background=\"background\"\n      :current-page=\"currentPage\"\n      :page-sizes=\"[5, 10, 15, 20]\"\n      :page-size=\"5\"\n      layout=\"total, sizes, prev, pager, next, jumper\"\n      :total=\"totalCount\">\n    </el-pagination>\n\n\n\n    <!--违纪对话框表单-->\n    <el-dialog ref=\"form\" title=\"学员违纪处理\" :visible.sync=\"dialogViolationVisible\" width=\"30%\">\n      <el-form ref=\"form\" :model=\"violationForm\" label-width=\"80px\" >\n        \n        <el-form-item label=\"违纪扣分\">\n          <el-input v-model=\"violationForm.score\"></el-input>\n        </el-form-item>\n\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"violationHandle\">提交</el-button>\n          <el-button @click=\"dialogViolationVisible = false\">取消</el-button>\n        </el-form-item>\n      </el-form>\n    </el-dialog>\n\n\n  </div>\n</template>\n\n<script>\nimport { page, add, update, deleteById, selectById,violationHandle} from \"@/api/student.js\";\nimport { findAll } from \"@/api/clazz.js\";\n\nexport default {\n  data() {\n    return {\n      background: true,\n      // 每页显示的条数\n      pageSize: 5,\n      // 总记录数\n      totalCount: 100,\n      // 当前页码\n      currentPage: 1,\n      // 添加数据对话框是否展示的标记\n      dialogVisible: false,\n      // 学员违纪对话框是否展示的标记\n      dialogViolationVisible: false,\n      // 模型数据\n      searchStu: {\n        name: \"\",\n        no: \"\",\n        degree: \"\",\n        clazzId: \"\"\n      },\n      student: {\n        name: \"\",\n        no: \"\",\n        gender: \"\",\n        phone: \"\",\n        degree: \"\",\n        classId: \"\"\n      },\n      violationForm: {\n        id:\"\",\n        score:\"\"\n      },\n      clazzList: [],\n      genderList: [{id: 1,name: \"男\"},{id: 2,name: \"女\"}],\n      degreeList: [\n        {id: 1, name: \"初中\"},\n        {id: 2, name: \"高中\"},\n        {id: 3, name: \"大专\"},\n        {id: 4, name: \"本科\"},\n        {id: 5, name: \"硕士\"},\n        {id: 6, name: \"博士\"}\n      ],\n\n      beginTime: \"\",\n      endTime: \"\",\n\n      // 被选中的id数组\n      selectedIds: [],\n      // 复选框选中数据集合\n      multipleSelection: [],\n      // 表格数据\n      tableData: []\n    };\n  },\n\n  mounted() {\n    this.page(); //当页面加载完成后，发送异步请求，获取数据\n    findAll().then((result) => {\n      this.clazzList = result.data.data;\n    });\n  },\n  \n  methods: {\n    // 查询分页数据\n    page() {\n      page(\n        this.searchStu.name,\n        this.searchStu.no,\n        this.searchStu.degree,\n        this.searchStu.clazzId,\n        this.currentPage,\n        this.pageSize\n      ).then((res) => {\n        this.totalCount = res.data.data.total;\n        this.tableData = res.data.data.rows;\n      });\n    },\n\n    // 复选框选中后执行的方法\n    handleSelectionChange(val) {\n      this.multipleSelection = val;\n    },\n\n    // 查询方法\n    onSubmit() {\n      this.currentPage = 1;\n      this.page();\n    },\n\n    clear(){\n      this.searchStu = {name: \"\", no: \"\", degree: \"\", clazzId: \"\"};\n      this.page();\n    },\n\n    // 保存数据\n    save() {\n      let operator;\n\n      if (this.student.id) {//修改\n        operator = update(this.student);\n      } else { //添加\n        operator = add(this.student);\n      }\n\n      operator.then((resp) => {\n        if (resp.data.code == 1) {\n          this.dialogVisible = false;\n          this.page();\n          this.$message({ message: \"恭喜你，保存成功\", type: \"success\" });\n          this.emp = { image: \"\" };\n        } else {\n          this.$message.error(resp.data.msg);\n        }\n      });\n    },\n\n    update(id) {\n      //1. 打开窗口\n      this.dialogVisible = true;\n      //2. 发送请求\n\n      selectById(id).then((result) => {\n        if (result.data.code == 1) {\n          this.student = result.data.data;\n        }\n      });\n    },\n\n    \n    //分页\n    handleSizeChange(val) {\n      // 重新设置每页显示的条数\n      this.pageSize = val;\n      this.page();\n    },\n\n    handleCurrentChange(val) {\n      // 重新设置当前页码\n      this.currentPage = val;\n      this.page();\n    },\n\n\n    //删除员工信息\n    deleteById(id){\n      this.$confirm(\"此操作将删除该数据, 是否继续?\", \"提示\", {\n        confirmButtonText: \"确定\",\n        cancelButtonText: \"取消\",\n        type: \"warning\",\n      }).then(() => {\n          //2. 发送AJAX请求\n          deleteById(id).then((resp) => {\n            if (resp.data.code == 1) {\n              //删除成功\n              this.$message.success(\"恭喜你，删除成功\");\n              this.page();\n            } else {\n              this.$message.error(resp.data.msg);\n            }\n          });\n      }).catch(() => {\n          //用户点击取消按钮\n          this.$message.info(\"已取消删除\");\n        });\n    },\n\n\n    // 批量删除员工信息\n    deleteByIds() {\n      if(this.selectedIds && this.selectedIds.length == 0){\n        this.$message.warning(\"请勾选要删除的记录\");\n        return;\n      }\n\n      // 弹出确认提示框\n      this.$confirm(\"此操作将删除该数据, 是否继续?\", \"提示\", {\n        confirmButtonText: \"确定\",\n        cancelButtonText: \"取消\",\n        type: \"warning\",\n      }).then(() => {\n          //用户点击确认按钮\n          //1. 创建id数组, 从 this.multipleSelection 获取即可\n          for (let i = 0; i < this.multipleSelection.length; i++) {\n            this.selectedIds[i] = this.multipleSelection[i].id;\n          }\n\n          //2. 发送AJAX请求\n          deleteById(this.selectedIds).then((resp) => {\n            if (resp.data.code == 1) {\n              //删除成功\n              this.$message.success(\"恭喜你，删除成功\");\n              this.page();\n            } else {\n              this.$message.error(resp.data.msg);\n            }\n          });\n      }).catch(() => {\n          //用户点击取消按钮\n          this.$message.info(\"已取消删除\");\n        });\n    },\n\n    //违纪\n    violationById(id){\n       this.violationForm = {};\n       this.dialogViolationVisible = true;\n       this.violationForm.id = id;\n    },\n\n    //学员违纪处理\n    violationHandle(){\n      violationHandle(this.violationForm.id , this.violationForm.score).then((result) => {\n          if (result.data.code == 1) {\n            this.$message.success(\"处理成功\");\n            this.dialogViolationVisible = false;\n            this.page();\n          } else {\n            this.$message.error(result.data.msg);\n          }\n      });\n    },\n\n    //文件上传相关\n    handleAvatarSuccess(res, file) {\n      this.emp.image = res.data;\n    },\n\n    beforeAvatarUpload(file) {\n      const isJPG = file.type === \"image/jpeg\";\n      const isLt2M = file.size / 1024 / 1024 < 2;\n      if (!isJPG) {\n        this.$message.error(\"上传头像图片只能是 JPG 格式!\");\n      }\n      if (!isLt2M) {\n        this.$message.error(\"上传头像图片大小不能超过 2MB!\");\n      }\n      return isJPG && isLt2M;\n    },\n  }\n};\n</script>\n<style>\n.avatar-uploader .el-upload {\n  border: 1px dashed #d9d9d9;\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n}\n.avatar-uploader .el-upload:hover {\n  border-color: #409eff;\n}\n.avatar-uploader-icon {\n  font-size: 28px;\n  color: #8c939d;\n  width: 100px;\n  height: 100px;\n  line-height: 100px;\n  text-align: center;\n}\n.avatar {\n  width: 100px;\n  height: 100px;\n  display: block;\n}\n</style>\n"]}]}