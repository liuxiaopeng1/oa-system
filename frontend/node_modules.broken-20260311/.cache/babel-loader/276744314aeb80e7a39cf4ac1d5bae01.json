{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js!/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/emp/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/emp/index.vue","mtime":1772186494249},{"path":"/Users/liuxiaopeng/tlias-web/babel.config.js","mtime":1772100774988},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js","mtime":1772101406962},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkMA,SACAA,eADA,EAEAC,aAFA,EAGAC,mBAHA,EAIAC,6BAJA,EAKAC,2BALA,QAMA,cANA;AAOA;AACA;AAEA;EACAC,IADA,kBACA;IACA;MACAC,gBADA;MAEA;MACAC,WAHA;MAIA;MACAC,eALA;MAMA;MACAC,cAPA;MAQA;MACAC,oBATA;MAUA;MACAC;QACAC,QADA;QAEAC;MAFA,CAXA;MAeAC;QACAC,YADA;QAEAH,QAFA;QAGAC,UAHA;QAIAG,SAJA;QAKAC,OALA;QAMAC,aANA;QAOAC;MAPA,CAfA;MAwBAC,YAxBA;MAyBAC;QAAAC;QAAAV;MAAA;QAAAU;QAAAV;MAAA,EAzBA;MA0BAW;QAAAD;QAAAV;MAAA;QAAAU;QAAAV;MAAA;QAAAU;QAAAV;MAAA;QAAAU;QAAAV;MAAA;QAAAU;QAAAV;MAAA,EA1BA;MA2BAY,aA3BA;MA4BAC,WA5BA;MA6BAP,aA7BA;MA8BA;MACAQ,eA/BA;MAgCA;MACAC,qBAjCA;MAkCA;MACAC,aAnCA;MAoCAC;QAAAA;MAAA,CApCA;MAqCAC;QACAf,WACA;UAAAgB;UAAAC;UAAAC;QAAA,CADA,EAEA;UAAAC;UAAAC;UAAAH;UAAAC;QAAA,CAFA,CADA;QAKArB,OACA;UAAAmB;UAAAC;UAAAC;QAAA,CADA,EAEA;UAAAC;UAAAC;UAAAH;UAAAC;QAAA,CAFA,CALA;QASApB,SACA;UAAAkB;UAAAC;UAAAC;QAAA,CADA;MATA;IArCA;EAmDA,CArDA;EAuDAG,OAvDA,qBAuDA;IAAA;;IACA,YADA,CACA;;IACAC;MACA;IACA,CAFA;EAGA,CA5DA;EA8DAC;IACA;IACAtC,IAFA,kBAEA;MAAA;;MACAuC;QACA3B,yBADA;QAEAC,6BAFA;QAGA2B,qBAHA;QAIAC,iBAJA;QAKAzC,sBALA;QAMAO;MANA,GAOAmC,IAPA,CAOA;QACA;QACA;MACA,CAVA;IAWA,CAdA;IAgBA;IACAC,qBAjBA,iCAiBAC,GAjBA,EAiBA;MACA;IACA,CAnBA;IAqBA;IACAC,QAtBA,sBAsBA;MACA;MACA;IACA,CAzBA;IA2BAC,KA3BA,mBA2BA;MACA;QAAAlC;QAAAC;MAAA;MACA,qBACA,iBADA;MAEA;MACA;IACA,CAjCA;IAmCA;IACAkC,IApCA,gBAoCAC,QApCA,EAoCA;MAAA;;MACA;MACA;QACA;UACA;;UACA;YAAA;YACAC;UACA,CAFA,MAEA;YAAA;YACAA;UACA;;UACAA;YACA;cACA;;cACA;;cACA;gBAAAjB;gBAAAkB;cAAA;;cACA;gBAAAlC;cAAA;YACA,CALA,MAKA;cACA;YACA;UACA,CATA;QAUA;MACA,CAnBA;IAoBA,CA1DA;IA6DAd,MA7DA,kBA6DAoB,EA7DA,EA6DA;MAAA;;MACA;MACA,0BAFA,CAGA;;MAEA6B;QACA;UACA;UACA;QACA;MACA,CALA;IAMA,CAxEA;IA2EA;IACAC,gBA5EA,4BA4EAR,GA5EA,EA4EA;MACA;MACA;MACA;IACA,CAhFA;IAkFAS,mBAlFA,+BAkFAT,GAlFA,EAkFA;MACA;MACA;MACA;IACA,CAtFA;IAyFA;IACAU,UA1FA,sBA0FAhC,EA1FA,EA0FA;MAAA;;MACA;QACAiC,uBADA;QAEAC,sBAFA;QAGAN;MAHA,GAIAR,IAJA,CAIA;QACA;QACAe;UACA;YACA;YACA;;YACA;UACA,CAJA,MAIA;YACA;UACA;QACA,CARA;MASA,CAfA,EAeAC,KAfA,CAeA;QACA;QACA;MACA,CAlBA;IAmBA,CA9GA;IAiHA;IACAvD,WAlHA,yBAkHA;MAAA;;MACA;QACA;QACA;MACA,CAJA,CAKA;;;MACA;QACAoD,uBADA;QAEAC,sBAFA;QAGAN;MAHA,GAIAR,IAJA,CAIA;QACA;QACA;QACA;UAAA;QAAA,GAHA,CAKA;;QACAe;UACA;YACA;YACA;;YACA;UACA,CAJA,MAIA;YACA;UACA;QACA,CARA;MASA,CAnBA,EAmBAC,KAnBA,CAmBA;QACA;QACA;MACA,CAtBA;IAuBA,CA/IA;IAiJAC,MAjJA,kBAiJAX,QAjJA,EAiJA;MACA;MACA;IACA,CApJA;IAsJA;IACAY,mBAvJA,+BAuJAC,GAvJA,EAuJAC,IAvJA,EAuJA;MACA;IACA,CAzJA;IA0JAC,kBA1JA,8BA0JAD,IA1JA,EA0JA;MACA;MACA;;MACA;QACA;MACA;;MACA;QACA;MACA;;MACA;IACA;EApKA,CA9DA;EAsOAE;IACA9C,SADA,qBACA0B,GADA,EACA;MACA;QACA;QACA;MACA,CAHA,MAGA;QACA;QACA;MACA;IACA;EATA;AAtOA","names":["page","add","update","deleteByIds","selectById","data","background","pageSize","totalCount","currentPage","dialogVisible","searchEmp","name","gender","emp","username","image","job","entrydate","deptId","deptList","genderList","id","jobList","beginTime","endTime","selectedIds","multipleSelection","tableData","token","rules","required","message","trigger","min","max","mounted","findAll","methods","pageEmp","begin","end","then","handleSelectionChange","val","onSubmit","clear","save","formName","operator","type","selectEmpById","handleSizeChange","handleCurrentChange","deleteById","confirmButtonText","cancelButtonText","deleteEmpByIds","catch","cancel","handleAvatarSuccess","res","file","beforeAvatarUpload","watch"],"sourceRoot":"src/views/emp","sources":["index.vue"],"sourcesContent":["<template>\n  <div class=\"app-container\">\n\n    <!--搜索表单-->\n    <el-form :inline=\"true\" :model=\"searchEmp\" class=\"demo-form-inline\">\n      <el-form-item label=\"姓名\">\n        <el-input\n          v-model=\"searchEmp.name\"\n          placeholder=\"请输入员工姓名\"\n        ></el-input>\n      </el-form-item>\n      <el-form-item label=\"性别\">\n        <el-select v-model=\"searchEmp.gender\" placeholder=\"请选择\">\n          <el-option label=\"男\" :value=\"1\"></el-option>\n          <el-option label=\"女\" :value=\"2\"></el-option>\n        </el-select>\n      </el-form-item>\n\n      <el-form-item label=\"入职时间\">\n        <el-date-picker\n          v-model=\"entrydate\"\n          clearable\n          value-format=\"yyyy-MM-dd\"\n          type=\"daterange\"\n          placeholder=\"选择日期\"\n          range-separator=\"至\"\n          start-placeholder=\"开始日期\"\n          end-placeholder=\"结束日期\"\n          style=\"width: 400px; margin-left: 20px\"\n        ></el-date-picker>\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" @click=\"onSubmit\">查询</el-button>\n         <el-button type=\"info\" @click=\"clear\">清空</el-button>\n      </el-form-item>\n    </el-form>\n\n\n\n    <!--按钮-->\n    <el-row>\n      <el-button type=\"danger\" size=\"medium\" @click=\"deleteByIds\">- 批量删除</el-button>\n      <el-button type=\"primary\" size=\"medium\" @click=\"dialogVisible = true; emp = { image: ''};\" >+ 新增员工</el-button>\n    </el-row>\n\n    <!--添加数据对话框表单-->\n    <el-dialog ref=\"form\" title=\"编辑员工\" :visible.sync=\"dialogVisible\" width=\"30%\">\n      <el-form :model=\"emp\" :rules=\"rules\" ref=\"emp\" label-width=\"80px\" size=\"mini\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"emp.username\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"员工姓名\"  prop=\"name\">\n          <el-input v-model=\"emp.name\"></el-input>\n        </el-form-item>\n\n        <el-form-item label=\"性别\"  prop=\"gender\">\n          <el-select v-model=\"emp.gender\" placeholder=\"请选择\" style=\"width:100%\" >\n             <el-option\n              v-for=\"item in genderList\"\n              :key=\"item.value\"\n              :label=\"item.name\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"头像\">\n          <el-upload\n            class=\"avatar-uploader\"\n            action=\"/api/upload\"\n            :headers=\"token\"\n            name=\"image\"\n            :show-file-list=\"false\"\n            :on-success=\"handleAvatarSuccess\"\n            :before-upload=\"beforeAvatarUpload\"\n          >\n            <img v-if=\"emp.image\" :src=\"emp.image\" class=\"avatar\" />\n            <i v-else class=\"el-icon-plus avatar-uploader-icon\"></i>\n          </el-upload>\n        </el-form-item>\n\n        <el-form-item label=\"职位\">\n          <el-select v-model=\"emp.job\" placeholder=\"请选择\" value-key=\"emp.job\" style=\"width:100%\">\n            <el-option\n              v-for=\"item in jobList\"\n              :key=\"item.value\"\n              :label=\"item.name\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"入职日期\">\n          <el-date-picker\n            v-model=\"emp.entrydate\"\n            clearable\n            type=\"date\"\n            value-format=\"yyyy-MM-dd\" \n            placeholder=\"选择日期\"\n            size=\"small\"\n            style=\"width:100%\"\n          ></el-date-picker>\n        </el-form-item>\n\n        <el-form-item label=\"归属部门\">\n          <el-select v-model=\"emp.deptId\" placeholder=\"请选择\" style=\"width:100%\">\n            <!-- \n            <el-option label=\"学工部\" value=\"1\"></el-option>\n            <el-option label=\"教研部\" value=\"2\"></el-option>\n             -->\n            <el-option\n              v-for=\"item in deptList\"\n              :key=\"item.value\"\n              :label=\"item.name\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"save('emp')\">提交</el-button>\n          <el-button @click=\"cancel('emp')\">取消</el-button>\n        </el-form-item>\n      </el-form>\n    </el-dialog>\n\n    <br>\n\n    <!--表格-->\n    <template>\n      <el-table :data=\"tableData\" style=\"width: 100%\" border @selection-change=\"handleSelectionChange\">\n        <el-table-column type=\"selection\" width=\"55\"  align=\"center\"></el-table-column>\n        <el-table-column  prop=\"name\"  label=\"姓名\"  align=\"center\"></el-table-column>\n        <el-table-column prop=\"image\" label=\"头像\" align=\"center\">\n          <template slot-scope=\"{ row }\">\n            <el-image style=\"width: auto; height: 40px; border: none; cursor: pointer\" :src=\"row.image\"></el-image>\n          </template>\n        </el-table-column>\n\n        <el-table-column align=\"center\" label=\"性别\">\n          <template slot-scope=\"scope\">\n            <span style=\"margin-right: 10px\">\n            {{scope.row.gender === 1 ? \"男\" : \"女\"}}</span>\n          </template>\n        </el-table-column>\n\n        <el-table-column align=\"center\" label=\"职位\">\n          <template slot-scope=\"scope\">\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.job == 1\">班主任</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.job == 2\">讲师</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.job == 3\">学工主管</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.job == 4\">教研主管</span>\n            <span style=\"margin-right: 10px\" v-if=\"scope.row.job == 5\">咨询师</span>\n          </template>\n        </el-table-column>\n\n        <el-table-column align=\"center\" label=\"日职日期\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.entrydate }}\n          </template>\n        </el-table-column>\n        <el-table-column align=\"center\" label=\"最后操作时间\">\n          <template slot-scope=\"scope\">\n            {{scope.row.updateTime ? scope.row.updateTime.replace('T',' '):''}}\n          </template>\n        </el-table-column>\n\n        <el-table-column align=\"center\" label=\"操作\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"primary\" size=\"small\" @click=\"update(scope.row.id)\">编辑</el-button>\n            <el-button type=\"danger\" size=\"small\" @click=\"deleteById(scope.row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </template>\n\n    <br>\n\n    <!--分页工具条-->\n    <el-pagination\n      @size-change=\"handleSizeChange\"\n      @current-change=\"handleCurrentChange\"\n      :background=\"background\"\n      :current-page=\"currentPage\"\n      :page-sizes=\"[5, 10, 15, 20]\"\n      :page-size=\"5\"\n      layout=\"total, sizes, prev, pager, next, jumper\"\n      :total=\"totalCount\">\n    </el-pagination>\n  </div>\n</template>\n\n<script>\nimport {\n  page as pageEmp,\n  add as addEmp,\n  update as updateEmp,\n  deleteByIds as deleteEmpByIds,\n  selectById as selectEmpById\n} from \"@/api/emp.js\";\nimport { findAll } from \"@/api/dept.js\";\nimport { getToken } from '@/utils/auth';\n\nexport default {\n  data() {\n    return {\n      background: true,\n      // 每页显示的条数\n      pageSize: 5,\n      // 总记录数\n      totalCount: 100,\n      // 当前页码\n      currentPage: 1,\n      // 添加数据对话框是否展示的标记\n      dialogVisible: false,\n      // 品牌模型数据\n      searchEmp: {\n        name: \"\",\n        gender: \"\",\n      },\n      emp: {\n        username: \"\",\n        name: \"\",\n        gender: \"\",\n        image: \"\",\n        job: \"\",\n        entrydate: \"\",\n        deptId: \"\"\n      },\n      deptList: [],\n      genderList: [{id: 1,name: \"男\"},{id: 2,name: \"女\"}],\n      jobList: [{id: 1,name: \"班主任\"},{id: 2,name: \"讲师\"},{id: 3, name: \"学工主管\"},{id: 4,name: \"教研主管\"},{id: 5,name: \"咨询师\"}],\n      beginTime: \"\",\n      endTime: \"\",\n      entrydate: \"\",\n      // 被选中的id数组\n      selectedIds: [],\n      // 复选框选中数据集合\n      multipleSelection: [],\n      // 表格数据\n      tableData: [],\n      token: {token: getToken()},\n      rules: {\n          username: [\n            {required: true, message: '请输入用户名', trigger: 'blur' },\n            {min: 2, max: 20, message: '长度在 2 到 20 个字符', trigger: 'blur' }\n          ],\n          name: [\n            {required: true, message: '请输入姓名', trigger: 'blur' },\n            {min: 2, max: 10, message: '长度在 2 到 10 个字符', trigger: 'blur' }\n          ],\n          gender: [\n            {required: true, message: '请选择性别', trigger: 'change' }\n          ]\n        }\n    };\n  },\n\n  mounted() {\n    this.page(); //当页面加载完成后，发送异步请求，获取数据\n    findAll().then((result) => {\n      this.deptList = result.data.data;\n    });\n  },\n  \n  methods: {\n    // 查询分页数据\n    page() {\n      pageEmp({\n        name: this.searchEmp.name,\n        gender: this.searchEmp.gender,\n        begin: this.beginTime,\n        end: this.endTime,\n        page: this.currentPage,\n        pageSize: this.pageSize\n      }).then((res) => {\n        this.totalCount = res.data.data.total;\n        this.tableData = res.data.data.rows;\n      });\n    },\n\n    // 复选框选中后执行的方法\n    handleSelectionChange(val) {\n      this.multipleSelection = val;\n    },\n\n    // 查询方法\n    onSubmit() {\n      this.currentPage = 1;\n      this.page();\n    },\n\n    clear(){\n      this.searchEmp = {name: \"\", gender: \"\"};\n      this.beginTime = \"\",\n      this.endTime = \"\";\n      this.entrydate = \"\";\n      this.page();\n    },\n    \n    // 添加数据\n    save(formName) {\n      //校验表单\n      this.$refs[formName].validate((valid) => {\n          if (valid) {\n            let operator;\n            if (this.emp.id) {//修改\n              operator = updateEmp(this.emp);\n            } else { //新增\n              operator = addEmp(this.emp);\n            }\n            operator.then((resp) => {\n              if (resp.data.code == 1) {\n                this.dialogVisible = false;\n                this.page();\n                this.$message({ message: \"恭喜你，保存成功\", type: \"success\" });\n                this.emp = { image: \"\" };\n              } else {\n                this.$message.error(resp.data.msg);\n              }\n            });\n          }\n      });\n    },\n\n\n    update(id) {\n      //1. 打开窗口\n      this.dialogVisible = true;\n      //2. 发送请求\n\n      selectEmpById(id).then((result) => {\n        if (result.data.code == 1) {\n          this.emp = result.data.data;\n          this.emp;\n        }\n      });\n    },\n\n    \n    //分页\n    handleSizeChange(val) {\n      // 重新设置每页显示的条数\n      this.pageSize = val;\n      this.page();\n    },\n\n    handleCurrentChange(val) {\n      // 重新设置当前页码\n      this.currentPage = val;\n      this.page();\n    },\n\n\n    //删除员工信息\n    deleteById(id){\n      this.$confirm(\"此操作将删除该数据, 是否继续?\", \"提示\", {\n        confirmButtonText: \"确定\",\n        cancelButtonText: \"取消\",\n        type: \"warning\",\n      }).then(() => {\n          //2. 发送AJAX请求\n          deleteEmpByIds(id).then((resp) => {\n            if (resp.data.code == 1) {\n              //删除成功\n              this.$message.success(\"恭喜你，删除成功\");\n              this.page();\n            } else {\n              this.$message.error(resp.data.msg);\n            }\n          });\n      }).catch(() => {\n          //用户点击取消按钮\n          this.$message.info(\"已取消删除\");\n        });\n    },\n\n\n    // 批量删除员工信息\n    deleteByIds() {\n      if (!this.multipleSelection.length) {\n        this.$message.warning(\"请先选择要删除的数据\");\n        return;\n      }\n      // 弹出确认提示框\n      this.$confirm(\"此操作将删除该数据, 是否继续?\", \"提示\", {\n        confirmButtonText: \"确定\",\n        cancelButtonText: \"取消\",\n        type: \"warning\",\n      }).then(() => {\n          //用户点击确认按钮\n          //1. 创建id数组, 从 this.multipleSelection 获取即可\n          this.selectedIds = this.multipleSelection.map(item => item.id);\n\n          //2. 发送AJAX请求\n          deleteEmpByIds(this.selectedIds).then((resp) => {\n            if (resp.data.code == 1) {\n              //删除成功\n              this.$message.success(\"恭喜你，删除成功\");\n              this.page();\n            } else {\n              this.$message.error(resp.data.msg);\n            }\n          });\n      }).catch(() => {\n          //用户点击取消按钮\n          this.$message.info(\"已取消删除\");\n        });\n    },\n\n    cancel(formName){\n      this.dialogVisible = false;\n      this.$refs[formName].resetFields();\n    },\n\n    //文件上传相关\n    handleAvatarSuccess(res, file) {\n      this.emp.image = res.data;\n    },\n    beforeAvatarUpload(file) {\n      const isImage = file.type === \"image/jpeg\" || file.type === \"image/png\";\n      const isLt2M = file.size / 1024 / 1024 < 2;\n      if (!isImage) {\n        this.$message.error(\"上传头像图片只能是 JPG/PNG 格式!\");\n      }\n      if (!isLt2M) {\n        this.$message.error(\"上传头像图片大小不能超过 2MB!\");\n      }\n      return isImage && isLt2M;\n    },\n  },\n\n\n  watch: {\n    entrydate(val) {\n      if (val && val.length >= 2) {\n        this.beginTime = val[0];\n        this.endTime = val[1];\n      } else {\n        this.beginTime = \"\";\n        this.endTime = \"\";\n      }\n    },\n  },\n};\n</script>\n<style>\n.avatar-uploader .el-upload {\n  border: 1px dashed #d9d9d9;\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n}\n.avatar-uploader .el-upload:hover {\n  border-color: #409eff;\n}\n.avatar-uploader-icon {\n  font-size: 28px;\n  color: #8c939d;\n  width: 100px;\n  height: 100px;\n  line-height: 100px;\n  text-align: center;\n}\n.avatar {\n  width: 100px;\n  height: 100px;\n  display: block;\n}\n</style>\n"]}]}