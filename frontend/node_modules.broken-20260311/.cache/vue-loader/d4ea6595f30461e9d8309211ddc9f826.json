{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/classes/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/classes/index.vue","mtime":1772186341154},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js","mtime":1772101406962},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA6FA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/classes","sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :inline=\"true\" :model=\"searchClazz\">\n      <el-form-item label=\"班级名称\">\n        <el-input v-model=\"searchClazz.name\" placeholder=\"请输入班级名称\" clearable />\n      </el-form-item>\n      <el-form-item label=\"开课时间\">\n        <el-date-picker\n          v-model=\"dateRange\"\n          type=\"daterange\"\n          value-format=\"yyyy-MM-dd\"\n          range-separator=\"至\"\n          start-placeholder=\"开始日期\"\n          end-placeholder=\"结束日期\"\n          clearable\n        />\n      </el-form-item>\n      <el-form-item>\n        <el-button type=\"primary\" @click=\"handleSearch\">查询</el-button>\n        <el-button @click=\"handleResetSearch\">清空</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row>\n      <el-button type=\"danger\" @click=\"handleBatchDelete\">批量删除</el-button>\n      <el-button type=\"primary\" @click=\"openAddDialog\">新增班级</el-button>\n    </el-row>\n\n    <el-table :data=\"tableData\" border style=\"margin-top: 16px\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n      <el-table-column type=\"index\" label=\"序号\" width=\"70\" align=\"center\" />\n      <el-table-column prop=\"name\" label=\"班级名称\" align=\"center\" />\n      <el-table-column prop=\"room\" label=\"班级教室\" align=\"center\" />\n      <el-table-column prop=\"masterId\" label=\"班主任\" align=\"center\">\n        <template slot-scope=\"scope\">\n          {{ getMasterName(scope.row.masterId) }}\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"beginDate\" label=\"开课时间\" align=\"center\" />\n      <el-table-column prop=\"endDate\" label=\"结课时间\" align=\"center\" />\n      <el-table-column label=\"最后操作时间\" align=\"center\">\n        <template slot-scope=\"scope\">\n          {{ scope.row.updateTime ? scope.row.updateTime.replace('T', ' ') : '' }}\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"180\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"primary\" size=\"mini\" @click=\"openEditDialog(scope.row.id)\">编辑</el-button>\n          <el-button type=\"danger\" size=\"mini\" @click=\"handleDelete(scope.row.id)\">删除</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <el-pagination\n      style=\"margin-top: 16px\"\n      :current-page=\"currentPage\"\n      :page-size=\"pageSize\"\n      :page-sizes=\"[5, 10, 15, 20]\"\n      layout=\"total, sizes, prev, pager, next, jumper\"\n      :total=\"total\"\n      @size-change=\"handleSizeChange\"\n      @current-change=\"handleCurrentChange\"\n    />\n\n    <el-dialog :title=\"form.id ? '编辑班级' : '新增班级'\" :visible.sync=\"dialogVisible\" width=\"500px\">\n      <el-form ref=\"clazzForm\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-form-item label=\"班级名称\" prop=\"name\">\n          <el-input v-model=\"form.name\" />\n        </el-form-item>\n        <el-form-item label=\"班级教室\" prop=\"room\">\n          <el-input v-model=\"form.room\" />\n        </el-form-item>\n        <el-form-item label=\"开课时间\" prop=\"beginDate\">\n          <el-date-picker v-model=\"form.beginDate\" type=\"date\" value-format=\"yyyy-MM-dd\" placeholder=\"选择日期\" style=\"width: 100%\" />\n        </el-form-item>\n        <el-form-item label=\"结课时间\" prop=\"endDate\">\n          <el-date-picker v-model=\"form.endDate\" type=\"date\" value-format=\"yyyy-MM-dd\" placeholder=\"选择日期\" style=\"width: 100%\" />\n        </el-form-item>\n        <el-form-item label=\"班主任\" prop=\"masterId\">\n          <el-select v-model=\"form.masterId\" style=\"width: 100%\" placeholder=\"请选择班主任\">\n            <el-option v-for=\"item in empList\" :key=\"item.id\" :label=\"item.name\" :value=\"item.id\" />\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSave\">确定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { add, deleteByIds, page, selectById, update } from '@/api/clazz'\nimport { findAll as findAllEmp } from '@/api/emp'\n\nconst defaultForm = {\n  name: '',\n  room: '',\n  beginDate: '',\n  endDate: '',\n  masterId: ''\n}\n\nexport default {\n  data() {\n    return {\n      searchClazz: {\n        name: ''\n      },\n      dateRange: [],\n      begin: '',\n      end: '',\n      tableData: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      dialogVisible: false,\n      form: { ...defaultForm },\n      selectedIds: [],\n      empList: [],\n      rules: {\n        name: [{ required: true, message: '请输入班级名称', trigger: 'blur' }],\n        room: [{ required: true, message: '请输入班级教室', trigger: 'blur' }],\n        beginDate: [{ required: true, message: '请选择开课时间', trigger: 'change' }],\n        endDate: [{ required: true, message: '请选择结课时间', trigger: 'change' }],\n        masterId: [{ required: true, message: '请选择班主任', trigger: 'change' }]\n      }\n    }\n  },\n  mounted() {\n    this.fetchEmpList()\n    this.fetchList()\n  },\n  methods: {\n    fetchEmpList() {\n      findAllEmp().then(res => {\n        if (res.data.code === 1) {\n          this.empList = res.data.data || []\n        }\n      })\n    },\n    fetchList() {\n      page({\n        name: this.searchClazz.name,\n        begin: this.begin,\n        end: this.end,\n        page: this.currentPage,\n        pageSize: this.pageSize\n      }).then(res => {\n        if (res.data.code === 1) {\n          this.total = res.data.data.total\n          this.tableData = res.data.data.rows\n        }\n      })\n    },\n    handleSearch() {\n      this.currentPage = 1\n      this.fetchList()\n    },\n    handleResetSearch() {\n      this.searchClazz.name = ''\n      this.dateRange = []\n      this.begin = ''\n      this.end = ''\n      this.currentPage = 1\n      this.fetchList()\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.fetchList()\n    },\n    handleCurrentChange(pageNo) {\n      this.currentPage = pageNo\n      this.fetchList()\n    },\n    handleSelectionChange(rows) {\n      this.selectedIds = rows.map(item => item.id)\n    },\n    openAddDialog() {\n      this.form = { ...defaultForm }\n      this.dialogVisible = true\n      this.$nextTick(() => {\n        if (this.$refs.clazzForm) {\n          this.$refs.clazzForm.clearValidate()\n        }\n      })\n    },\n    openEditDialog(id) {\n      selectById(id).then(res => {\n        if (res.data.code === 1) {\n          this.form = { ...res.data.data }\n          this.dialogVisible = true\n          this.$nextTick(() => {\n            if (this.$refs.clazzForm) {\n              this.$refs.clazzForm.clearValidate()\n            }\n          })\n        }\n      })\n    },\n    handleSave() {\n      this.$refs.clazzForm.validate(valid => {\n        if (!valid) return\n        const request = this.form.id ? update(this.form) : add(this.form)\n        request.then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('保存成功')\n            this.dialogVisible = false\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      })\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该班级吗？', '提示', { type: 'warning' }).then(() => {\n        deleteByIds(id).then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('删除成功')\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleBatchDelete() {\n      if (!this.selectedIds.length) {\n        this.$message.warning('请先选择要删除的数据')\n        return\n      }\n      this.$confirm('确认批量删除选中的班级吗？', '提示', { type: 'warning' }).then(() => {\n        deleteByIds(this.selectedIds).then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('删除成功')\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    getMasterName(masterId) {\n      const match = this.empList.find(item => item.id === masterId)\n      return match ? match.name : masterId\n    }\n  },\n  watch: {\n    dateRange(val) {\n      if (val && val.length === 2) {\n        this.begin = val[0]\n        this.end = val[1]\n      } else {\n        this.begin = ''\n        this.end = ''\n      }\n    }\n  }\n}\n</script>\n"]}]}