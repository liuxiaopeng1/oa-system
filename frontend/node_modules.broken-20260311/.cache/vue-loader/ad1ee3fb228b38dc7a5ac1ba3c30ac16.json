{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/student/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/student/index.vue","mtime":1772186391004},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/babel-loader/lib/index.js","mtime":1772101406962},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgHA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/student","sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :inline=\"true\" :model=\"searchStudent\">\n      <el-form-item label=\"姓名\">\n        <el-input v-model=\"searchStudent.name\" placeholder=\"请输入姓名\" clearable />\n      </el-form-item>\n      <el-form-item label=\"学号\">\n        <el-input v-model=\"searchStudent.no\" placeholder=\"请输入学号\" clearable />\n      </el-form-item>\n      <el-form-item label=\"学历\">\n        <el-select v-model=\"searchStudent.degree\" placeholder=\"请选择\" clearable>\n          <el-option v-for=\"item in degreeList\" :key=\"item.id\" :label=\"item.name\" :value=\"item.id\" />\n        </el-select>\n      </el-form-item>\n      <el-form-item label=\"班级\">\n        <el-select v-model=\"searchStudent.clazzId\" placeholder=\"请选择\" clearable>\n          <el-option v-for=\"item in clazzList\" :key=\"item.id\" :label=\"item.name\" :value=\"item.id\" />\n        </el-select>\n      </el-form-item>\n      <el-form-item>\n        <el-button type=\"primary\" @click=\"handleSearch\">查询</el-button>\n        <el-button @click=\"handleResetSearch\">清空</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row>\n      <el-button type=\"danger\" @click=\"handleBatchDelete\">批量删除</el-button>\n      <el-button type=\"primary\" @click=\"openAddDialog\">新增学员</el-button>\n    </el-row>\n\n    <el-table :data=\"tableData\" border style=\"margin-top: 16px\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n      <el-table-column type=\"index\" label=\"序号\" width=\"70\" align=\"center\" />\n      <el-table-column prop=\"name\" label=\"姓名\" align=\"center\" />\n      <el-table-column prop=\"no\" label=\"学号\" align=\"center\" />\n      <el-table-column prop=\"gender\" label=\"性别\" align=\"center\">\n        <template slot-scope=\"scope\">\n          {{ scope.row.gender === 1 ? '男' : '女' }}\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"phone\" label=\"手机号\" align=\"center\" />\n      <el-table-column prop=\"degree\" label=\"学历\" align=\"center\">\n        <template slot-scope=\"scope\">\n          {{ getDegreeName(scope.row.degree) }}\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"clazzName\" label=\"班级\" align=\"center\" />\n      <el-table-column prop=\"violationCount\" label=\"违纪次数\" align=\"center\" />\n      <el-table-column prop=\"violationScore\" label=\"违纪扣分\" align=\"center\" />\n      <el-table-column label=\"操作\" width=\"260\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button size=\"mini\" type=\"warning\" @click=\"openViolationDialog(scope.row.id)\">违纪</el-button>\n          <el-button size=\"mini\" type=\"primary\" @click=\"openEditDialog(scope.row.id)\">编辑</el-button>\n          <el-button size=\"mini\" type=\"danger\" @click=\"handleDelete(scope.row.id)\">删除</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <el-pagination\n      style=\"margin-top: 16px\"\n      :current-page=\"currentPage\"\n      :page-size=\"pageSize\"\n      :page-sizes=\"[5, 10, 15, 20]\"\n      layout=\"total, sizes, prev, pager, next, jumper\"\n      :total=\"total\"\n      @size-change=\"handleSizeChange\"\n      @current-change=\"handleCurrentChange\"\n    />\n\n    <el-dialog :title=\"form.id ? '编辑学员' : '新增学员'\" :visible.sync=\"dialogVisible\" width=\"560px\">\n      <el-form ref=\"studentForm\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-form-item label=\"姓名\" prop=\"name\">\n          <el-input v-model=\"form.name\" />\n        </el-form-item>\n        <el-form-item label=\"学号\" prop=\"no\">\n          <el-input v-model=\"form.no\" />\n        </el-form-item>\n        <el-form-item label=\"性别\" prop=\"gender\">\n          <el-select v-model=\"form.gender\" style=\"width: 100%\">\n            <el-option label=\"男\" :value=\"1\" />\n            <el-option label=\"女\" :value=\"2\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"手机号\" prop=\"phone\">\n          <el-input v-model=\"form.phone\" />\n        </el-form-item>\n        <el-form-item label=\"学历\" prop=\"degree\">\n          <el-select v-model=\"form.degree\" style=\"width: 100%\">\n            <el-option v-for=\"item in degreeList\" :key=\"item.id\" :label=\"item.name\" :value=\"item.id\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"班级\" prop=\"clazzId\">\n          <el-select v-model=\"form.clazzId\" style=\"width: 100%\">\n            <el-option v-for=\"item in clazzList\" :key=\"item.id\" :label=\"item.name\" :value=\"item.id\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item v-if=\"form.id\" label=\"违纪次数\" prop=\"violationCount\">\n          <el-input-number v-model=\"form.violationCount\" :min=\"0\" :step=\"1\" style=\"width: 100%\" />\n        </el-form-item>\n        <el-form-item v-if=\"form.id\" label=\"违纪扣分\" prop=\"violationScore\">\n          <el-input-number v-model=\"form.violationScore\" :min=\"0\" :step=\"1\" style=\"width: 100%\" />\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSave\">确定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { findAll as findAllClazz } from '@/api/clazz'\nimport { add, deleteByIds, handleViolation, page, selectById, update } from '@/api/student'\n\nconst defaultForm = {\n  name: '',\n  no: '',\n  gender: 1,\n  phone: '',\n  degree: 4,\n  clazzId: '',\n  violationCount: 0,\n  violationScore: 0\n}\n\nexport default {\n  data() {\n    return {\n      searchStudent: {\n        name: '',\n        no: '',\n        degree: '',\n        clazzId: ''\n      },\n      tableData: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      selectedIds: [],\n      dialogVisible: false,\n      form: { ...defaultForm },\n      clazzList: [],\n      degreeList: [\n        { id: 1, name: '初中' },\n        { id: 2, name: '高中' },\n        { id: 3, name: '大专' },\n        { id: 4, name: '本科' },\n        { id: 5, name: '硕士' },\n        { id: 6, name: '博士' }\n      ],\n      rules: {\n        name: [{ required: true, message: '请输入姓名', trigger: 'blur' }],\n        no: [{ required: true, message: '请输入学号', trigger: 'blur' }],\n        gender: [{ required: true, message: '请选择性别', trigger: 'change' }],\n        phone: [{ required: true, message: '请输入手机号', trigger: 'blur' }],\n        degree: [{ required: true, message: '请选择学历', trigger: 'change' }],\n        clazzId: [{ required: true, message: '请选择班级', trigger: 'change' }]\n      }\n    }\n  },\n  mounted() {\n    this.fetchClazzList()\n    this.fetchList()\n  },\n  methods: {\n    fetchClazzList() {\n      findAllClazz().then(res => {\n        if (res.data.code === 1) {\n          this.clazzList = res.data.data || []\n        }\n      })\n    },\n    fetchList() {\n      page({\n        ...this.searchStudent,\n        page: this.currentPage,\n        pageSize: this.pageSize\n      }).then(res => {\n        if (res.data.code === 1) {\n          this.total = res.data.data.total\n          this.tableData = res.data.data.rows\n        }\n      })\n    },\n    handleSearch() {\n      this.currentPage = 1\n      this.fetchList()\n    },\n    handleResetSearch() {\n      this.searchStudent = {\n        name: '',\n        no: '',\n        degree: '',\n        clazzId: ''\n      }\n      this.currentPage = 1\n      this.fetchList()\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.fetchList()\n    },\n    handleCurrentChange(pageNo) {\n      this.currentPage = pageNo\n      this.fetchList()\n    },\n    handleSelectionChange(rows) {\n      this.selectedIds = rows.map(item => item.id)\n    },\n    openAddDialog() {\n      this.form = { ...defaultForm }\n      this.dialogVisible = true\n      this.$nextTick(() => {\n        if (this.$refs.studentForm) {\n          this.$refs.studentForm.clearValidate()\n        }\n      })\n    },\n    openEditDialog(id) {\n      selectById(id).then(res => {\n        if (res.data.code === 1) {\n          this.form = { ...res.data.data }\n          this.dialogVisible = true\n          this.$nextTick(() => {\n            if (this.$refs.studentForm) {\n              this.$refs.studentForm.clearValidate()\n            }\n          })\n        }\n      })\n    },\n    handleSave() {\n      this.$refs.studentForm.validate(valid => {\n        if (!valid) return\n        const request = this.form.id ? update(this.form) : add(this.form)\n        request.then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('保存成功')\n            this.dialogVisible = false\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      })\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该学员吗？', '提示', { type: 'warning' }).then(() => {\n        deleteByIds(id).then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('删除成功')\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    handleBatchDelete() {\n      if (!this.selectedIds.length) {\n        this.$message.warning('请先选择要删除的数据')\n        return\n      }\n      this.$confirm('确认批量删除选中的学员吗？', '提示', { type: 'warning' }).then(() => {\n        deleteByIds(this.selectedIds).then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('删除成功')\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    openViolationDialog(id) {\n      this.$prompt('请输入扣分分值', '违纪处理', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        inputPattern: /^([1-9]\\d*|0)$/,\n        inputErrorMessage: '请输入大于等于 0 的整数'\n      }).then(({ value }) => {\n        handleViolation(id, value).then(res => {\n          if (res.data.code === 1) {\n            this.$message.success('处理成功')\n            this.fetchList()\n          } else {\n            this.$message.error(res.data.msg)\n          }\n        })\n      }).catch(() => {})\n    },\n    getDegreeName(degree) {\n      const match = this.degreeList.find(item => item.id === degree)\n      return match ? match.name : degree\n    }\n  }\n}\n</script>\n"]}]}