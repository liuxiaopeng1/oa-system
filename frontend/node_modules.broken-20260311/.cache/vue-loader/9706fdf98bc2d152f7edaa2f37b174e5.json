{"remainingRequest":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/liuxiaopeng/tlias-web/src/views/student-report/index.vue?vue&type=style&index=0&id=7484f5ba&lang=css&","dependencies":[{"path":"/Users/liuxiaopeng/tlias-web/src/views/student-report/index.vue","mtime":1772187011994},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/css-loader/dist/cjs.js","mtime":1772101400671},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1772101405965},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/postcss-loader/src/index.js","mtime":1772101407292},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/cache-loader/dist/cjs.js","mtime":1772101402856},{"path":"/Users/liuxiaopeng/tlias-web/node_modules/vue-loader/lib/index.js","mtime":1772101405978}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCmgxIHsKICB0ZXh0LWFsaWduOiBjZW50ZXI7Cn0KCi5jaGFydC1jb250YWluZXIgewogIGRpc3BsYXk6IGZsZXg7Cn0KLmNoYXJ0LWNvbnRhaW5lciA+IGRpdiB7CiAgZmxleDogMTsKfQo="},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkFA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/student-report","sourcesContent":["<template>\n  <div class=\"chart-container\">\n\n    <div  style=\"width: 100%; \">\n      <h1>班级人数统计</h1> <br>\n      <div ref=\"studentChartRef\" style=\"width: 100%; height: 500px\"></div>\n    </div>\n\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport { getStudentData } from \"@/api/report.js\";\n\nexport default {\n  data() {\n    return {\n      clazzCountList: [],\n      studentCountList: [],\n      studentChart: null\n    }\n  },\n\n  mounted() { \n    this.getStudentData(); //获取班级学生统计数据\n    window.addEventListener('resize', this.handleResize)\n  },\n  beforeDestroy() {\n    window.removeEventListener('resize', this.handleResize)\n    if (this.studentChart) {\n      this.studentChart.dispose()\n      this.studentChart = null\n    }\n  },\n\n  methods: {\n    //获取班级学生统计数据\n    getStudentData(){\n      getStudentData().then((result) => {\n          if(result.data.code == 1){\n             this.clazzCountList = result.data.data.categoryList;\n             this.studentCountList = result.data.data.dataList;\n             \n             this.initChart1();\n          }\n      });\n    },\n    \n    initChart1() {\n      if (!this.studentChart) {\n        this.studentChart = echarts.init(this.$refs.studentChartRef)\n      }\n       \n      let option = {\n        xAxis: {\n          type: 'category',\n          data: this.clazzCountList\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [\n          {\n            data: this.studentCountList,\n            type: 'bar'\n          }\n        ]\n      };\n      \n      this.studentChart.setOption(option);\n    },\n    handleResize() {\n      if (this.studentChart) {\n        this.studentChart.resize()\n      }\n    }\n  }\n};\n</script>\n\n<style>\n  h1 {\n    text-align: center;\n  }\n\n  .chart-container {\n    display: flex;\n  }\n  .chart-container > div {\n    flex: 1;\n  }\n</style>\n"]}]}